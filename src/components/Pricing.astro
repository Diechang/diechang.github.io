---
// src/components/Pricing.astro
// pricing.mdを元にした料金目安セクション

import PricingCard from "./PricingCard.astro";
import PricingItem from "./PricingItem.astro";
import PricingOptionItem from "./PricingOptionItem.astro";
import PricingCommonTerms from "./PricingCommonTerms.astro";

const codingPrices = [
  {
    name: "トップページ",
    desc: "メインビジュアル・複数セクション構成",
    period: "8 h〜",
    price: "¥20,000〜",
  },
  {
    name: "下層ページ（汎用）",
    desc: "テキスト中心・標準レイアウト",
    period: "2 h〜",
    price: "¥5,000〜",
  },
  {
    name: "フォームページ",
    desc: "マークアップ・フロントバリデーションのみ",
    period: "4 h〜",
    price: "¥10,000〜",
  },
  {
    name: "LP（縦長）",
    desc: "セクション構成・縦長レイアウト",
    period: "10 h〜",
    price: "¥25,000〜",
  },
];

const frontendPrices = [
  {
    name: "UIコンポーネント開発",
    desc: "共通パーツ設計・Storybook対応など",
    period: "4 h〜",
    price: "¥16,000〜",
  },
  {
    name: "SPA / SSRページ実装",
    desc: "Vue / Nuxt・React / Next によるページ単位の実装",
    period: "8 h〜",
    price: "¥32,000〜",
  },
  {
    name: "API連携・状態管理",
    desc: "REST / GraphQL 連携・Pinia / Redux など",
    period: "4 h〜",
    price: "¥16,000〜",
  },
];

const wordpressPrices = [
  {
    name: "オリジナルテーマ構築",
    desc: "デザインカンプからのフルスクラッチ",
    price: "¥80,000〜",
  },
  {
    name: "既存テーマ カスタマイズ",
    desc: "ソース解読・修正・追加実装",
    price: "¥30,000〜",
  },
  {
    name: "プラグイン対応・保守",
    desc: "プラグイン選定・設定・軽微な改修",
    price: "¥15,000〜",
  },
];

const codingOptions = [
  {
    name: "素材スライス（PSD / AI → Web用書き出し）",
    price: "+¥5,000〜",
    unit: "/ 案件",
  },
  { name: "レスポンシブ対応", price: "+¥5,000〜", unit: "/ ページ" },
  {
    name: "スクロール演出・パララックス",
    price: "+¥5,000〜",
    unit: "/ ページ",
  },
  {
    name: "アニメーション実装（その他）",
    price: "+¥5,000〜",
    unit: "/ ページ",
  },
  { name: "WordPress組み込み", price: "+¥10,000〜", unit: "/ ページ" },
  {
    name: "フォーム送信処理（formrun等の連携）",
    price: "+¥10,000〜",
    unit: "/ フォーム",
  },
];

const commonTerms = [
  "表示価格はすべて税別です",
  "修正対応は2回まで無料、以降は ¥2,500 / h にて承ります",
  "デザイン制作（Figma・XD等）は別途ご相談ください",
  "納期・支払いタイミングはご相談のうえ決定します",
];
---

<section id="pricing" class="py-24 bg-bg relative overflow-hidden">
  <!-- 背景装飾 -->
  <div
    class="absolute top-1/4 left-0 -ml-32 w-[500px] h-[500px] bg-primary/10 rounded-full blur-3xl pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-1/4 right-0 -mr-32 w-[500px] h-[500px] bg-accent/10 rounded-full blur-3xl pointer-events-none"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-text-main mb-4">
        料金目安
      </h2>
      <p class="text-text-muted max-w-2xl mx-auto">
        ご依頼の際の料金目安です。ご予算や納期に合わせた柔軟なご提案も可能ですので、まずはお気軽にご相談ください。
      </p>
    </div>

    <!-- メイングリッド (2カラム構成) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8 items-start">
      <!-- 左カラム: コーディングカード (基本料金 + オプションを内包) -->
      <PricingCard
        title="コーディング"
        badge="時間単価 ¥2,500"
        description="デザインカンプ（Figma / XD / PSD）からのHTML / CSS / JSコーディング。"
        note="工数はデザインの複雑さにより変動します。まずはご相談ください。"
      >
        <!-- 基本メニュー -->
        <div class="mb-8">
          <h4
            class="font-semibold text-text-main mb-4 tracking-wider flex items-center uppercase"
          >
            <span class="w-1.5 h-1.5 bg-primary rounded-full mr-2"></span>
            基本制作料金
          </h4>
          <div class="space-y-4">
            {
              codingPrices.map((item) => (
                <PricingItem
                  name={item.name}
                  desc={item.desc}
                  price={item.price}
                  period={item.period}
                />
              ))
            }
          </div>
        </div>

        <!-- オプションメニュー -->
        <div class="pt-6 border-t border-text-muted/10">
          <h4
            class="font-semibold text-text-main mb-4 tracking-wider flex items-center uppercase"
          >
            <span class="w-1.5 h-1.5 bg-primary rounded-full mr-2"></span>
            オプション
          </h4>
          <div class="space-y-3">
            {
              codingOptions.map((opt) => (
                <PricingOptionItem
                  name={opt.name}
                  price={opt.price}
                  unit={opt.unit}
                />
              ))
            }
          </div>
        </div>
      </PricingCard>

      <!-- 右カラム: フロントエンド開発カード ＆ WordPress構築カード を縦に並べる -->
      <div class="flex flex-col gap-8">
        <!-- フロントエンド開発 -->
        <PricingCard
          title="フロントエンド開発"
          badge="時間単価 ¥4,000"
          description="Vue / Nuxt・React / Next によるコンポーネント開発・SPA構築・API連携など。"
          note="要件により工数が大きく変わるため、まずはヒアリングからご相談ください。"
        >
          <div class="space-y-4">
            {
              frontendPrices.map((item) => (
                <PricingItem
                  name={item.name}
                  desc={item.desc}
                  price={item.price}
                  period={item.period}
                />
              ))
            }
          </div>
        </PricingCard>

        <!-- WordPress構築 -->
        <PricingCard
          title="WordPress構築"
          badge="クラシックテーマ対応"
          description="クラシックテーマ（PHPベース）のみ対応。デザインカンプからのフルスクラッチ、既存テーマのカスタマイズに対応します。"
          note="既存ソースの解読・整理が必要なため、規模・状態によって金額が大きく変わります。"
        >
          <div class="space-y-4">
            {
              wordpressPrices.map((item) => (
                <PricingItem
                  name={item.name}
                  desc={item.desc}
                  price={item.price}
                />
              ))
            }
          </div>
        </PricingCard>
      </div>
    </div>

    <!-- ブロック3: 共通事項 (1カラム) -->
    <PricingCommonTerms terms={commonTerms} />
  </div>
</section>
